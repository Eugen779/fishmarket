# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_name
NEXT_PUBLIC_ENVIRONMENT=development

# Backend
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://fishmarket:fishmarket_dev_pass@localhost:5432/fishmarket
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production-12345
REFRESH_TOKEN_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@fishmarket.md

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE=+1234567890

# Admin
ADMIN_EMAIL=admin@fishmarket.md
ADMIN_PASSWORD=Admin123!

# Payment
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# App
APP_NAME=FishMarket
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
